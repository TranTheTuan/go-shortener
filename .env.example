# Copy to .env and adjust. Consumed by both the app (caarlos0/env) and the
# Makefile migration targets.

# Application
ENV=development

# HTTP server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=10s
SERVER_PPROF_ADDR=localhost:6060
# Prometheus /metrics endpoint. Empty disables it. Bind 0.0.0.0 in-cluster; never route via ingress.
SERVER_METRICS_ADDR=0.0.0.0:9464

# PostgreSQL
DB_HOST=192.168.1.205
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=hdp12345
DB_NAME=hdp
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=500
DB_MAX_IDLE_CONNS=150
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# URL shortener
SHORTENER_BASE_URL=http://localhost:8080
SHORTENER_CODE_LENGTH=7
SHORTENER_CACHE_TTL=24h

# Authentication — Keycloak (OIDC resource server; the app validates tokens only)
# ISSUER: the PUBLIC token issuer; must match the access token's `iss` exactly.
#         Confirm via: curl -s <issuer>/.well-known/openid-configuration | jq .issuer
KEYCLOAK_ISSUER=https://auth.cd.me/realms/<realm>
# JWKS_URL: the IN-CLUSTER certs endpoint. Build it by hand (internal host + the
#           standard Keycloak path). Do NOT copy jwks_uri from .well-known — that
#           returns the public host and would defeat in-cluster fetching.
#           Add the service port if not 80 (e.g. ...svc.cluster.local:8080/...).
KEYCLOAK_JWKS_URL=http://keycloak-keycloakx-http.keycloak.svc.cluster.local/realms/<realm>/protocol/openid-connect/certs
# CLIENT_ID: expected client; the token must carry it in `aud` OR `azp`. Keycloak
#            sets azp to the requesting client by default, so no audience mapper
#            is needed (add one only if you prefer matching on aud). Empty = skip.
KEYCLOAK_CLIENT_ID=go-shortener

# Daily link quota (per authenticated user)
QUOTA_DEFAULT_PLAN_CODE=basic
QUOTA_BASIC_FALLBACK_LIMIT=10
QUOTA_BREAKER_MAX_FAILURES=10
QUOTA_BREAKER_OPEN_TIMEOUT=5m

# Kafka (leave empty for inline fallback / local dev)
KAFKA_BROKERS=
KAFKA_CLICK_TOPIC=link-clicks
KAFKA_CONSUMER_GROUP=click-consumer
KAFKA_BULK_JOB_TOPIC=bulk-link-jobs
KAFKA_BULK_CONSUMER_GROUP=bulk-job-consumer
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_TLS_ENABLED=false

# Cloudflare R2 (leave empty to disable bulk-upload endpoints)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=bulk-uploads
