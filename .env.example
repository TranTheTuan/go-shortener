# Copy to .env and adjust. Consumed by both the app (caarlos0/env) and the
# Makefile migration targets.

# Application
ENV=development

# HTTP server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=120s
SERVER_SHUTDOWN_TIMEOUT=10s
SERVER_PPROF_ADDR=localhost:6060

# PostgreSQL
DB_HOST=192.168.1.205
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=hdp12345
DB_NAME=hdp
DB_SSLMODE=disable
DB_TIMEZONE=UTC
DB_MAX_OPEN_CONNS=500
DB_MAX_IDLE_CONNS=150
DB_CONN_MAX_LIFETIME=5m

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

# URL shortener
SHORTENER_BASE_URL=http://localhost:8080
# Comma-separated API keys accepted on the X-API-Key header (empty = reject all writes)
SHORTENER_API_KEYS=dev-key-1,dev-key-2
SHORTENER_CODE_LENGTH=7
SHORTENER_CACHE_TTL=24h

# Authentication
# JWT signing secret for access tokens. The default is accepted only when
# ENV=development; any other environment must set a strong, random value.
AUTH_JWT_SECRET=dev-insecure-change-me
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=168h
AUTH_BCRYPT_COST=12
